{
  "expo": {
    "name": "SolFarm",
    "slug": "solfarm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "solfarm",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.solfarm.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para identificar sua região e exibir dados de satélite relevantes.",
        "NSLocationAlwaysUsageDescription": "Usamos sua localização para monitoramento contínuo das suas áreas.",
        "NSCameraUsageDescription": "Usamos a câmera para fotos das suas lavouras.",
        "NSPhotoLibraryUsageDescription": "Acesso à galeria para adicionar fotos às suas áreas.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.solfarm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite monitorar sua área rural."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "493d20cb-12cc-499d-8c47-58b3d866df52"
      }
    },
    "owner": "antonio88-88"
  }
}
