{
  "expo": {
    "name": "SolFarm",
    "slug": "solfarm-app",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "solfarm",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.solfarm.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O SolFarm usa sua localização apenas para localizar suas áreas agrícolas no mapa e buscar imagens de satélite da região.",
        "NSCameraUsageDescription": "O SolFarm usa a câmera para você fotografar suas lavouras e gerar diagnóstico por IA da saúde da plantação.",
        "NSPhotoLibraryUsageDescription": "O SolFarm acessa a galeria para você selecionar fotos das suas lavouras para diagnóstico por IA.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.solfarm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O SolFarm usa sua localização apenas para localizar suas áreas agrícolas no mapa e buscar imagens de satélite da região."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "72d7177f-4f24-4f98-8a89-851a496922bc"
      }
    },
    "owner": "antonioterra"
  }
}
